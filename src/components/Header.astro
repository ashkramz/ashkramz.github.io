---
import { site } from "../config/site";

// Normalize the current path so we can highlight the active link.
const current = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) => (href.replace(/\/+$/, "") || "/") === current;
---

<header class="site-header" data-header>
  <div class="site-header__inner container">
    <a class="site-header__brand" href="/" aria-label="Home">
      <span class="site-header__monogram">{site.couple.monogram}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "site-nav__link",
                  {
                    "is-active": isActive(item.href),
                    "site-nav__link--cta": item.href === "/rsvp",
                  },
                ]}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      class="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-nav-toggle
    >
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>
  </div>
</header>

<!-- Full-screen mobile menu — kept OUTSIDE <header> on purpose: the header's
     backdrop-filter would otherwise trap this fixed-position panel inside the
     thin header bar. -->
<div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
  <nav aria-label="Mobile">
    <ul class="mobile-menu__list">
      {
        site.nav.map((item, i) => (
          <li style={`--reveal-delay: ${0.05 + i * 0.045}s`}>
            <a
              href={item.href}
              class:list={["mobile-menu__link", { "is-active": isActive(item.href) }]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <p class="mobile-menu__signature">
    {site.wedding.dateDisplay} &nbsp;·&nbsp; {site.wedding.location}
  </p>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: color-mix(in srgb, var(--ivory) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
  }

  .site-header__monogram {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    letter-spacing: 0.12em;
    color: var(--ink);
  }

  .site-nav__list {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 2vw, 1.9rem);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-nav__link {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-soft);
    padding-block: 0.4rem;
    position: relative;
  }

  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background-color: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease);
  }

  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--ink);
  }
  .site-nav__link:hover::after,
  .site-nav__link.is-active::after {
    transform: scaleX(1);
  }

  /* RSVP stands apart as a quiet outlined pill */
  .site-nav__link--cta {
    border: 1px solid var(--ink);
    border-radius: 999px;
    padding: 0.45rem 1.15rem;
    color: var(--ink);
    transition: background-color 0.3s var(--ease), color 0.3s var(--ease);
  }
  .site-nav__link--cta::after {
    display: none;
  }
  .site-nav__link--cta:hover,
  .site-nav__link--cta.is-active {
    background-color: var(--ink);
    color: var(--ivory);
  }

  /* Hamburger (hidden on desktop) */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
  }
  .nav-toggle__bar {
    display: block;
    width: 26px;
    height: 1.5px;
    background-color: var(--ink);
    transition: transform 0.3s var(--ease), opacity 0.2s var(--ease);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle__bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 4.5rem 0 0 0;
    z-index: 95;
    background-color: var(--ivory);
    padding: clamp(1.5rem, 6vw, 3rem);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  /* `display: flex` above would defeat the hidden attribute — restore it */
  .mobile-menu[hidden] {
    display: none;
  }
  .mobile-menu:not([hidden]) {
    animation: menu-fade 0.35s var(--ease);
  }
  @keyframes menu-fade {
    from {
      opacity: 0;
    }
  }
  .mobile-menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  /* Each link drifts in with a slight stagger (delay set inline per item) */
  .mobile-menu:not([hidden]) .mobile-menu__list li {
    opacity: 0;
    transform: translateY(10px);
    animation: menu-item 0.5s var(--ease) forwards;
    animation-delay: var(--reveal-delay, 0s);
  }
  @keyframes menu-item {
    to {
      opacity: 1;
      transform: none;
    }
  }
  .mobile-menu__link {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.7rem;
    color: var(--ink-soft);
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--line);
  }
  .mobile-menu__link.is-active,
  .mobile-menu__link:hover {
    color: var(--ink);
  }
  .mobile-menu__signature {
    margin-top: auto;
    padding-top: 2rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--ink-soft);
    text-align: center;
    max-width: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-menu:not([hidden]),
    .mobile-menu:not([hidden]) .mobile-menu__list li {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* Mobile breakpoint */
  @media (max-width: 860px) {
    .site-nav {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      menu.hidden = !open;
      document.body.style.overflow = open ? "hidden" : "";
    };

    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });

    // Close when a link is tapped or Escape is pressed.
    menu.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => setOpen(false))
    );
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
  }
</script>
