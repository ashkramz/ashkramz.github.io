---
import type { ScheduleEvent } from "../config/site";
interface Props {
  event: ScheduleEvent;
}
const { event } = Astro.props;

// A "get directions" link appears once the address is filled in (not [TBD]).
const hasAddress = !!event.address && !event.address.startsWith("[TBD");
const mapUrl = hasAddress
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${event.venue}, ${event.address}`)}`
  : null;

// "Add to calendar" links, generated from the day + time strings.
// Hawaiʻi is UTC-10 year-round (no daylight saving), so the conversion is
// simple and unambiguous. Hidden automatically while day/time are [TBD].
const MONTHS: Record<string, number> = {
  january: 0, february: 1, march: 2, april: 3, may: 4, june: 5,
  july: 6, august: 7, september: 8, october: 9, november: 10, december: 11,
};
function parseStartUTC(day: string, time: string): Date | null {
  const dm = day.match(/([A-Za-z]+)\s+(\d{1,2}),\s*(\d{4})/);
  const tm = time.match(/(\d{1,2}):(\d{2})\s*([AP]M)/i);
  if (!dm || !tm) return null;
  const month = MONTHS[dm[1].toLowerCase()];
  if (month === undefined) return null;
  let hours = Number(tm[1]) % 12;
  if (tm[3].toUpperCase() === "PM") hours += 12;
  // HST → UTC is +10 hours
  return new Date(Date.UTC(Number(dm[3]), month, Number(dm[2]), hours + 10, Number(tm[2])));
}
const fmtICS = (d: Date) => d.toISOString().replace(/[-:]/g, "").replace(/\.\d{3}/, "");
const start = parseStartUTC(event.day, event.time);
let icsHref: string | null = null;
let gcalHref: string | null = null;
if (start) {
  const end = new Date(start.getTime() + 2 * 3600000); // assume ~2 hours
  const location = hasAddress ? `${event.venue}, ${event.address}` : event.venue;
  const ics = [
    "BEGIN:VCALENDAR",
    "VERSION:2.0",
    "PRODID:-//Ashley and Michael Wedding//EN",
    "BEGIN:VEVENT",
    `UID:${fmtICS(start)}-${event.title.replace(/\W+/g, "")}@ashkramz.github.io`,
    `DTSTAMP:${fmtICS(new Date())}`,
    `DTSTART:${fmtICS(start)}`,
    `DTEND:${fmtICS(end)}`,
    `SUMMARY:${event.title} — Ashley & Michael's Wedding`,
    `LOCATION:${location.replace(/,/g, "\\,")}`,
    `DESCRIPTION:${event.note.replace(/,/g, "\\,")}`,
    "END:VEVENT",
    "END:VCALENDAR",
  ].join("\r\n");
  icsHref = `data:text/calendar;charset=utf-8,${encodeURIComponent(ics)}`;
  gcalHref =
    "https://calendar.google.com/calendar/render?action=TEMPLATE" +
    `&text=${encodeURIComponent(`${event.title} — Ashley & Michael's Wedding`)}` +
    `&dates=${fmtICS(start)}/${fmtICS(end)}` +
    `&location=${encodeURIComponent(location)}` +
    `&details=${encodeURIComponent(event.note)}` +
    "&ctz=Pacific/Honolulu";
}
const icsFilename = `${event.title.toLowerCase().replace(/\W+/g, "-")}.ics`;
---

<article class="schedule-card reveal">
  <div class="schedule-card__when">
    <p class="schedule-card__day">{event.day}</p>
    <p class="schedule-card__time">{event.time}</p>
  </div>
  <div class="schedule-card__body">
    <h3 class="schedule-card__title">{event.title}</h3>
    <p class="schedule-card__venue">
      {event.venue}
      {hasAddress && (
        <span class="schedule-card__address"> — {event.address}</span>
      )}
    </p>
    <p class="schedule-card__note">{event.note}</p>
    <div class="schedule-card__foot">
      {
        event.attire && (
          <p class="schedule-card__attire">
            <span class="schedule-card__attire-label">Attire</span>
            {event.attire}
          </p>
        )
      }
      <span class="schedule-card__actions">
        {
          mapUrl && (
            <a
              class="schedule-card__action"
              href={mapUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              View map <span aria-hidden="true">→</span>
            </a>
          )
        }
        {
          icsHref && (
            <a class="schedule-card__action" href={icsHref} download={icsFilename}>
              Add to calendar <span aria-hidden="true">↓</span>
            </a>
          )
        }
        {
          gcalHref && (
            <a
              class="schedule-card__action"
              href={gcalHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              Google
            </a>
          )
        }
      </span>
    </div>
  </div>
</article>

<style>
  .schedule-card {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: clamp(1rem, 4vw, 3rem);
    padding: clamp(1.75rem, 1.2rem + 2vw, 2.75rem);
    background-color: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    transition: border-color 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .schedule-card:hover {
    border-color: var(--accent);
    box-shadow: 0 18px 40px -28px rgba(22, 19, 15, 0.35);
  }
  .schedule-card + .schedule-card {
    margin-top: 1.25rem;
  }
  .schedule-card__when {
    border-right: 1px solid var(--line);
    padding-right: clamp(1rem, 3vw, 2rem);
  }
  .schedule-card__day {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
  }
  .schedule-card__time {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    margin-top: 0.4rem;
    color: var(--ink);
  }
  .schedule-card__title {
    font-size: var(--step-h3);
  }
  .schedule-card__venue {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-top: 0.5rem;
  }
  .schedule-card__address {
    text-transform: none;
    letter-spacing: 0.01em;
    color: var(--ink-soft);
  }
  .schedule-card__note {
    margin-top: 0.9rem;
    color: var(--ink-soft);
  }
  .schedule-card__foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    margin-top: 1.1rem;
  }
  .schedule-card__attire {
    font-size: 0.85rem;
    color: var(--ink);
  }
  .schedule-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
  }
  .schedule-card__action {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s var(--ease);
  }
  .schedule-card__action:hover {
    border-color: var(--accent);
  }
  .schedule-card__attire-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
    margin-right: 0.6rem;
  }

  @media (max-width: 640px) {
    .schedule-card {
      grid-template-columns: 1fr;
    }
    .schedule-card__when {
      border-right: 0;
      border-bottom: 1px solid var(--line);
      padding-right: 0;
      padding-bottom: 1rem;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
    .schedule-card__time {
      margin-top: 0;
    }
  }
</style>
