---
import type { ScheduleEvent } from "../config/site";
interface Props {
  event: ScheduleEvent;
}
const { event } = Astro.props;

// A "get directions" link appears once the address is filled in (not [TBD]).
const hasAddress = !!event.address && !event.address.startsWith("[TBD");
const mapUrl = hasAddress
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${event.venue}, ${event.address}`)}`
  : null;
---

<article class="schedule-card reveal">
  <div class="schedule-card__when">
    <p class="schedule-card__day">{event.day}</p>
    <p class="schedule-card__time">{event.time}</p>
  </div>
  <div class="schedule-card__body">
    <h3 class="schedule-card__title">{event.title}</h3>
    <p class="schedule-card__venue">
      {event.venue}
      {hasAddress && (
        <span class="schedule-card__address"> — {event.address}</span>
      )}
    </p>
    <p class="schedule-card__note">{event.note}</p>
    <div class="schedule-card__foot">
      {
        event.attire && (
          <p class="schedule-card__attire">
            <span class="schedule-card__attire-label">Attire</span>
            {event.attire}
          </p>
        )
      }
      {
        mapUrl && (
          <a
            class="schedule-card__map"
            href={mapUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            View map <span aria-hidden="true">→</span>
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  .schedule-card {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: clamp(1rem, 4vw, 3rem);
    padding: clamp(1.75rem, 1.2rem + 2vw, 2.75rem);
    background-color: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    transition: border-color 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  .schedule-card:hover {
    border-color: var(--accent);
    box-shadow: 0 18px 40px -28px rgba(22, 19, 15, 0.35);
  }
  .schedule-card + .schedule-card {
    margin-top: 1.25rem;
  }
  .schedule-card__when {
    border-right: 1px solid var(--line);
    padding-right: clamp(1rem, 3vw, 2rem);
  }
  .schedule-card__day {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
  }
  .schedule-card__time {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    margin-top: 0.4rem;
    color: var(--ink);
  }
  .schedule-card__title {
    font-size: var(--step-h3);
  }
  .schedule-card__venue {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-top: 0.5rem;
  }
  .schedule-card__address {
    text-transform: none;
    letter-spacing: 0.01em;
    color: var(--ink-soft);
  }
  .schedule-card__note {
    margin-top: 0.9rem;
    color: var(--ink-soft);
  }
  .schedule-card__foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    margin-top: 1.1rem;
  }
  .schedule-card__attire {
    font-size: 0.85rem;
    color: var(--ink);
  }
  .schedule-card__map {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s var(--ease);
  }
  .schedule-card__map:hover {
    border-color: var(--accent);
  }
  .schedule-card__attire-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
    margin-right: 0.6rem;
  }

  @media (max-width: 640px) {
    .schedule-card {
      grid-template-columns: 1fr;
    }
    .schedule-card__when {
      border-right: 0;
      border-bottom: 1px solid var(--line);
      padding-right: 0;
      padding-bottom: 1rem;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
    .schedule-card__time {
      margin-top: 0;
    }
  }
</style>
