---
import { site } from "../config/site";
---

<section class="hero">
  <img
    class="hero__img"
    src={site.home.heroImage}
    alt={site.home.heroImageAlt}
    fetchpriority="high"
  />
  <div class="hero__scrim"></div>
  <div class="hero__content container center">
    <p class="hero__eyebrow eyebrow">{site.home.heroEyebrow}</p>
    <h1 class="hero__names">
      {site.couple.partnerA}
      <span class="hero__amp">&amp;</span>
      {site.couple.partnerB}
    </h1>
    <div class="hero__rule" aria-hidden="true"></div>
    <p class="hero__meta">
      {site.wedding.dayOfWeek}, {site.wedding.dateDisplay}
      <span class="hero__dot">·</span>
      {site.wedding.location}
    </p>
    <a class="btn btn--light hero__cta" href={site.home.ctaHref}>
      {site.home.ctaLabel}
    </a>
  </div>
  <div class="hero__scroll-cue" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(92vh, 820px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--ink);
  }
  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 65%;
    animation: hero-zoom 8s var(--ease) forwards;
  }
  @keyframes hero-zoom {
    from {
      transform: scale(1.07);
    }
    to {
      transform: scale(1);
    }
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to bottom,
        rgba(16, 13, 9, 0.3) 0%,
        rgba(16, 13, 9, 0.18) 38%,
        rgba(16, 13, 9, 0.5) 100%
      );
  }
  .hero__content {
    position: relative;
    color: var(--ivory);
    padding-block: 4rem;
  }

  /* Staged entrance: eyebrow → names → rule → meta → button */
  .hero__content > * {
    opacity: 0;
    transform: translateY(16px);
    animation: hero-rise 1s var(--ease) forwards;
  }
  .hero__eyebrow {
    animation-delay: 0.15s;
  }
  .hero__names {
    animation-delay: 0.3s;
  }
  .hero__rule {
    animation-delay: 0.55s;
  }
  .hero__meta {
    animation-delay: 0.7s;
  }
  .hero__cta {
    animation-delay: 0.95s;
  }
  @keyframes hero-rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero__eyebrow {
    color: rgba(251, 248, 242, 0.86);
  }
  .hero__names {
    color: var(--ivory);
    font-weight: 500;
    font-size: var(--step-display);
    line-height: 1.04;
    letter-spacing: 0.015em;
    margin-top: 1.1rem;
    text-shadow: 0 1px 30px rgba(0, 0, 0, 0.25);
  }
  .hero__amp {
    display: block;
    font-style: italic;
    font-weight: 400;
    font-size: 0.62em;
    margin-block: 0.05em;
    opacity: 0.92;
  }
  .hero__rule {
    width: 56px;
    height: 1px;
    margin: 1.7rem auto 0;
    background-color: rgba(251, 248, 242, 0.55);
  }
  .hero__meta {
    max-width: none;
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-size: clamp(0.8rem, 0.72rem + 0.4vw, 0.95rem);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: rgba(251, 248, 242, 0.92);
  }
  .hero__dot {
    margin-inline: 0.5rem;
    opacity: 0.7;
  }
  .hero__cta {
    margin-top: 2.2rem;
  }

  /* Slim pulsing line inviting the guest to scroll */
  .hero__scroll-cue {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 1px;
    height: 56px;
    transform: translateX(-50%);
    overflow: hidden;
    opacity: 0;
    animation: cue-appear 1s var(--ease) 1.4s forwards;
  }
  @keyframes cue-appear {
    to {
      opacity: 1;
    }
  }
  .hero__scroll-cue::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: rgba(251, 248, 242, 0.75);
    transform-origin: top;
    /* Pulses a handful of times, then rests — enough to invite scrolling
       without animating forever */
    animation: scroll-cue 2.4s var(--ease) 4;
  }
  @keyframes scroll-cue {
    0% {
      transform: translateY(-100%);
    }
    55% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(100%);
    }
  }

  @media (max-width: 600px) {
    .hero__meta {
      letter-spacing: 0.18em;
    }
    .hero__dot {
      display: block;
      height: 0;
      overflow: hidden;
      margin: 0.45rem 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__img,
    .hero__content > * {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .hero__scroll-cue {
      display: none;
    }
  }
</style>
