---
import { site } from "../config/site";
---

<section class="hero">
  <img
    class="hero__img"
    src={site.home.heroImage}
    alt={site.home.heroImageAlt}
    fetchpriority="high"
  />
  <div class="hero__scrim"></div>
  <div class="hero__content container center">
    <p class="hero__eyebrow eyebrow">{site.home.heroEyebrow}</p>
    <h1 class="hero__names">
      {site.couple.partnerA}
      <span class="hero__amp">&amp;</span>
      {site.couple.partnerB}
    </h1>
    <p class="hero__meta">
      {site.wedding.dayOfWeek}, {site.wedding.dateDisplay}
      <span class="hero__dot">·</span>
      {site.wedding.location}
    </p>
    <a class="btn btn--light hero__cta" href={site.home.ctaHref}>
      {site.home.ctaLabel}
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(92vh, 820px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--ink);
  }
  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 65%;
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to bottom,
        rgba(16, 13, 9, 0.28) 0%,
        rgba(16, 13, 9, 0.18) 38%,
        rgba(16, 13, 9, 0.46) 100%
      );
  }
  .hero__content {
    position: relative;
    color: var(--ivory);
    padding-block: 4rem;
  }
  .hero__eyebrow {
    color: rgba(251, 248, 242, 0.86);
  }
  .hero__names {
    color: var(--ivory);
    font-weight: 500;
    font-size: var(--step-display);
    line-height: 1.04;
    margin-top: 1.1rem;
    text-shadow: 0 1px 30px rgba(0, 0, 0, 0.25);
  }
  .hero__amp {
    display: block;
    font-style: italic;
    font-weight: 400;
    font-size: 0.62em;
    margin-block: 0.05em;
    opacity: 0.92;
  }
  .hero__meta {
    max-width: none;
    margin-top: 1.6rem;
    font-family: var(--font-sans);
    font-size: clamp(0.8rem, 0.72rem + 0.4vw, 0.95rem);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: rgba(251, 248, 242, 0.92);
  }
  .hero__dot {
    margin-inline: 0.5rem;
    opacity: 0.7;
  }
  .hero__cta {
    margin-top: 2.2rem;
  }

  @media (max-width: 600px) {
    .hero__meta {
      letter-spacing: 0.18em;
    }
    .hero__dot {
      display: block;
      height: 0;
      overflow: hidden;
      margin: 0.45rem 0;
    }
  }
</style>
