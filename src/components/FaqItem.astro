---
import type { FaqItem } from "../config/site";
interface Props {
  item: FaqItem;
}
const { item } = Astro.props;
---

<details class="faq-item">
  <summary class="faq-item__q">
    <span>{item.q}</span>
    <span class="faq-item__icon" aria-hidden="true"></span>
  </summary>
  <div class="faq-item__a">
    <p>{item.a}</p>
  </div>
</details>

<style>
  .faq-item {
    border-bottom: 1px solid var(--line);
  }
  /* Smooth expand/collapse in browsers that support ::details-content
     (older browsers simply open instantly — no harm done) */
  .faq-item::details-content {
    opacity: 0;
    block-size: 0;
    overflow: hidden;
    transition: content-visibility 0.45s allow-discrete, opacity 0.45s var(--ease),
      block-size 0.45s var(--ease);
  }
  .faq-item[open]::details-content {
    opacity: 1;
    block-size: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .faq-item::details-content {
      transition: none;
    }
  }
  .faq-item__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.4rem 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-serif);
    font-size: var(--step-h3);
    color: var(--ink);
  }
  .faq-item__q::-webkit-details-marker {
    display: none;
  }
  .faq-item__icon {
    position: relative;
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
  }
  .faq-item__icon::before,
  .faq-item__icon::after {
    content: "";
    position: absolute;
    background-color: var(--accent);
    transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);
  }
  .faq-item__icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    transform: translateY(-50%);
  }
  .faq-item__icon::after {
    left: 50%;
    top: 0;
    width: 1.5px;
    height: 100%;
    transform: translateX(-50%);
  }
  .faq-item[open] .faq-item__icon::after {
    opacity: 0;
    transform: translateX(-50%) scaleY(0);
  }
  .faq-item__a {
    padding-bottom: 1.5rem;
    color: var(--ink-soft);
  }
  .faq-item__a p {
    max-width: 70ch;
  }
</style>
