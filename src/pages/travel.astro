---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { site } from "../config/site";
const { travel } = site;
---

<BaseLayout
  title="Travel"
  description="Travel guidance for guests flying to Oʻahu, Hawaiʻi."
>
  <PageHeader eyebrow="Getting to the Island" title="Travel" intro={travel.intro} />

  <div class="container">
    <figure class="travel-banner reveal">
      <img
        src={travel.bannerImage}
        alt={travel.bannerImageAlt}
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>

  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="travel-grid">
        {
          travel.sections.map((section, i) => (
            <article class="travel-block reveal" style={`--reveal-delay: ${(i % 2) * 0.12}s`}>
              <p class="travel-block__num">{String(i + 1).padStart(2, "0")}</p>
              <h2 class="travel-block__heading">{section.heading}</h2>
              <div class="travel-block__body">
                {section.body.map((para) => <p>{para}</p>)}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .travel-banner {
    margin: 0 0 clamp(2.5rem, 2rem + 3vw, 4.5rem);
  }
  .travel-banner img {
    width: 100%;
    aspect-ratio: 21 / 9;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  @media (max-width: 640px) {
    .travel-banner img {
      aspect-ratio: 16 / 10;
    }
  }

  .travel-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 2rem + 3vw, 4.5rem) clamp(2rem, 4vw, 4rem);
  }
  .travel-block__num {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .travel-block__heading {
    font-size: var(--step-h3);
    margin-top: 0.4rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .travel-block__body > p {
    margin-top: 1rem;
    color: var(--ink-soft);
  }

  @media (max-width: 720px) {
    .travel-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
