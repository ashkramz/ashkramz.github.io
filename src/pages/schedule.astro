---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ScheduleCard from "../components/ScheduleCard.astro";
import { site } from "../config/site";
const { schedule } = site;
---

<BaseLayout
  title="Schedule"
  description="The schedule of events for the wedding weekend on Oʻahu."
>
  <PageHeader eyebrow="The Weekend" title="Schedule" intro={schedule.intro} />

  <section class="section" style="padding-top:0;">
    <div class="container">
      {schedule.events.map((event) => <ScheduleCard event={event} />)}
    </div>
  </section>
</BaseLayout>
