---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import FaqItem from "../components/FaqItem.astro";
import { site } from "../config/site";
const { faq } = site;
---

<BaseLayout
  title="FAQ"
  description="Frequently asked questions about the wedding weekend."
>
  <PageHeader eyebrow="Good to Know" title="FAQ" intro={faq.intro} />

  <section class="section" style="padding-top:0;">
    <div class="container container--narrow">
      <div class="faq-list reveal">
        {faq.items.map((item) => <FaqItem item={item} />)}
      </div>

      <p class="faq-cta center reveal">
        Still have a question?{" "}
        <a class="link-underline" href="/contact">Get in touch</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .faq-list {
    border-top: 1px solid var(--line);
  }
  .faq-cta {
    margin-top: 2.5rem;
    color: var(--ink-soft);
  }
</style>
