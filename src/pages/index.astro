---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Countdown from "../components/Countdown.astro";
import { site } from "../config/site";

// "The day at a glance" pulls straight from the Schedule — no extra editing.
const glanceEvents = site.schedule.events.slice(0, 3);
---

<BaseLayout>
  <Hero />

  <!-- Countdown -->
  <section class="section section--bone">
    <div class="container">
      <Countdown />
    </div>
  </section>

  <!-- Welcome -->
  <section class="section">
    <div class="container container--narrow center stack reveal">
      <p class="eyebrow">{site.wedding.dateDisplay} · {site.wedding.location}</p>
      <h2>{site.home.welcomeHeading}</h2>
      <hr class="divider" />
      {site.home.welcomeBody.map((para) => <p class="lead welcome__para">{para}</p>)}
    </div>
  </section>

  <!-- The day at a glance -->
  <section class="section section--bone">
    <div class="container center">
      <p class="eyebrow reveal">{site.wedding.dayOfWeek}, {site.wedding.dateDisplay}</p>
      <h2 class="glance__title reveal">The day at a glance</h2>
      <div class="glance reveal">
        {
          glanceEvents.map((event, i) => (
            <a class="glance__item" href="/schedule" style={`--reveal-delay: ${i * 0.1}s`}>
              <span class="glance__time">{event.time}</span>
              <span class="glance__name">{event.title}</span>
              <span class="glance__venue">{event.venue.split(",")[0]}</span>
            </a>
          ))
        }
      </div>
      <p class="glance__more reveal">
        <a class="link-underline" href="/schedule">View the full schedule</a>
      </p>
    </div>
  </section>

  <!-- Quick links -->
  <section class="section">
    <div class="container">
      <ul class="quicklinks">
        {
          site.home.quickLinks.map((link, i) => (
            <li class="quicklinks__item reveal" style={`--reveal-delay: ${i * 0.1}s`}>
              <a href={link.href} class="quicklinks__link">
                <span class="quicklinks__label">{link.label}</span>
                <span class="quicklinks__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .welcome__para {
    margin-inline: auto;
  }

  /* Day at a glance */
  .glance__title {
    margin-top: 0.9rem;
  }
  .glance {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: clamp(2.25rem, 2rem + 2vw, 3.5rem);
    border-block: 1px solid var(--line);
  }
  .glance__item {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: clamp(1.75rem, 1.4rem + 1.5vw, 2.75rem) 1rem;
    transition: background-color 0.35s var(--ease);
  }
  .glance__item + .glance__item {
    border-left: 1px solid var(--line);
  }
  .glance__item:hover {
    background-color: var(--paper);
  }
  .glance__time {
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 1.4rem + 1.4vw, 2.4rem);
    line-height: 1.1;
    color: var(--ink);
  }
  .glance__name {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
  }
  .glance__venue {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--ink-soft);
  }
  .glance__more {
    margin: 2.25rem auto 0;
    max-width: none;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  /* Quick links */
  .quicklinks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .quicklinks__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.6rem 1.8rem;
    background-color: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink);
    transition: border-color 0.3s var(--ease), transform 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
  }
  .quicklinks__link:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 14px 30px -18px rgba(22, 19, 15, 0.28);
  }
  .quicklinks__arrow {
    color: var(--accent);
    transition: transform 0.3s var(--ease);
  }
  .quicklinks__link:hover .quicklinks__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 720px) {
    .quicklinks {
      grid-template-columns: 1fr;
    }
    .glance {
      grid-template-columns: 1fr;
    }
    .glance__item + .glance__item {
      border-left: 0;
      border-top: 1px solid var(--line);
    }
  }
</style>
