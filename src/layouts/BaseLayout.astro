---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Gate from "../components/Gate.astro";
import { site } from "../config/site";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ${site.couple.firstNames}` : site.meta.title;
const pageDescription = description ?? site.meta.description;
const ogImage = new URL(site.meta.ogImage, Astro.site ?? Astro.url).toString();
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    <!-- Social sharing (Open Graph + Twitter) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#fbf8f2" />

    <!-- Keep the site out of search results — guests get the link directly -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Password gate check. Runs before first paint so there's no flash of
         content: sets <html data-gate="locked|open"> which CSS acts on. -->
    <script is:inline define:vars={{ gateEnabled: site.gate.enabled }}>
      let open = !gateEnabled;
      try {
        open = open || localStorage.getItem("am-gate") === "open";
      } catch {}
      document.documentElement.dataset.gate = open ? "open" : "locked";
    </script>
  </head>
  <body>
    <Gate />
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {
      /* Floating RSVP button — appears on phones after scrolling a bit,
         on every page except the RSVP page itself */
      Astro.url.pathname.replace(/\/+$/, "") !== "/rsvp" && (
        <a class="floating-rsvp" href="/rsvp" data-floating-rsvp>RSVP</a>
      )
    }

    <!-- Gentle fade-in on scroll. Pure progressive enhancement: if this script
         doesn't run, everything is still fully visible. -->
    <script>
      const reveals = document.querySelectorAll<HTMLElement>(".reveal");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce || !("IntersectionObserver" in window)) {
        reveals.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.08 }
        );
        reveals.forEach((el) => io.observe(el));
      }

      // Floating RSVP pill: fade in after the guest scrolls past the top
      const pill = document.querySelector<HTMLElement>("[data-floating-rsvp]");
      if (pill) {
        const update = () => {
          pill.classList.toggle("is-shown", window.scrollY > 480);
        };
        window.addEventListener("scroll", update, { passive: true });
        update();
      }
    </script>
  </body>
</html>
